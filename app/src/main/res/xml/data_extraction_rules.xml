<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="mydiary.db" />
        <include domain="database" path="mydiary.db-wal" />
        <include domain="database" path="mydiary.db-shm" />
        <exclude domain="file" path="diary_photos/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="mydiary.db" />
        <include domain="database" path="mydiary.db-wal" />
        <include domain="database" path="mydiary.db-shm" />
        <exclude domain="file" path="diary_photos/" />
    </device-transfer>
</data-extraction-rules>
